{
  "name": "react-native-webrtc-capture",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felix727144/react-native-webrtc-capture.git"
  },
  "description": "Fork of react-native-webrtc with VideoFrame Hook - AI Analysis, Screenshot, Encoding",
  "license": "MIT",
  "homepage": "https://github.com/felix727144/react-native-webrtc-capture.git",
  "keywords": [
    "react-component",
    "react-native",
    "ios",
    "android",
    "webrtc",
    "videoframe",
    "ai",
    "screenshot"
  ],
  "react-native": "src/index.ts",
  "types": "lib/typescript/index.d.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "files": [
    "src",
    "lib",
    "ios",
    "android",
    "apple",
    "macos",
    "Documentation"
  ],
  "peerDependencies": {
    "react-native": ">=0.60.0"
  },
  "scripts": {
    "lint": "eslint --max-warnings 0 . && tsc --noEmit",
    "lintfix": "eslint --max-warnings 0 --fix . && tsc --noEmit",
    "format": "tools/format.sh",
    "build": "bob build",
    "clean": "bob build --clean"
  },
  "devDependencies": {
    "@types/debug": "4.1.7",
    "@types/react": "^17.0.40",
    "@types/react-native": "^0.67.3",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "base64-js": "^1.5.1",
    "debug": "^4.4.3",
    "eslint": "^8.24.0",
    "eslint-plugin-import": "^2.26.0",
    "husky": "7.0.2",
    "lint-staged": "11.2.3",
    "prettier": "2.4.1",
    "react": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-builder-bob": "0.18.2",
    "typescript": "^4.6.2",
    "react-native-webrtc":"file:../../react-native-webrtc"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
